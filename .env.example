# =============================================================================
# NXTTRACK — environment variables (production VPS template)
# =============================================================================
# Copy this file to `.env` on the VPS, fill in real values, and NEVER commit it.
#   cp .env.example .env
#   nano .env
# Both PM2 processes (web + api) load this single file.
# =============================================================================

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── Public URL & domains ─────────────────────────────────────────────────────
# Apex domain. Tenant subdomains (slug.nxttrack.nl) resolve via this base.
APP_BASE_DOMAIN=nxttrack.nl
# Full base URL used to build invite links and other absolute URLs.
APP_BASE_URL=https://nxttrack.nl
# Exposed to the browser bundle (Next.js public env).
NEXT_PUBLIC_APP_URL=https://nxttrack.nl

# ── Ports (private, behind Nginx — never expose 6000-6001 publicly) ──────────
# nxttrack-web (Next.js)         → 6000
# nxttrack-api (Express)         → 6001
# (mockup-sandbox is dev-only and NOT deployed to production)
PORT=6000

# ── Supabase (PRODUCTIE project — de geüpgradede pro-instance) ───────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Sessions ─────────────────────────────────────────────────────────────────
SESSION_SECRET=

# ── Email — SendGrid API ─────────────────────────────────────────────────────
# Vraag een dedicated production API key aan via SendGrid → Settings → API Keys.
# Scope minimaal: "Mail Send: Full Access".
SENDGRID_API_KEY=

# Defaults voor afzender + tenant fallback
MAIL_BASE_DOMAIN=nxttrack.nl
MAIL_DEFAULT_FROM_NAME=NXTTRACK
MAIL_DEFAULT_FROM_EMAIL=no-reply@nxttrack.nl

# Marketing-formulier op nxttrack.nl/contact stuurt leads hierheen.
MARKETING_LEAD_RECIPIENT=hallo@nxttrack.nl
