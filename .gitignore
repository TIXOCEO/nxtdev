# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# ── compiled output ──────────────────────────────────────────────────
dist
build
tmp
out
out-tsc
*.tsbuildinfo
.expo
.expo-shared
.swc
.turbo

# Next.js
.next/
artifacts/*/.next/
next-env.d.ts

# ── dependencies ─────────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ── env & secrets (NEVER commit) ─────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
.env.development.local

# ── runtime / process managers ───────────────────────────────────────
.pm2/
logs/
*.log
ecosystem.local.config.cjs
pids/
*.pid
*.seed

# ── caches ───────────────────────────────────────────────────────────
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
/coverage
/.nyc_output
/.sass-cache

# ── test/debug ───────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
testem.log
/typings

# ── IDEs / editors ───────────────────────────────────────────────────
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# ── system files ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo

# ── Replit-specific ──────────────────────────────────────────────────
.local/
.pythonlibs/
.config/
.upm/

# ── attached chat uploads (not part of the app) ──────────────────────
attached_assets/

# ── deploy artifacts ─────────────────────────────────────────────────
*.tar.gz
*.zip
